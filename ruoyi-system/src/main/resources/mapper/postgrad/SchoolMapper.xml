<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.postgrad.mapper.SchoolMapper">

    <resultMap type="School" id="SchoolResult">
        <id     property="id"            column="id"              />
        <result property="name"          column="name"            />
        <result property="shortName"     column="short_name"      />
        <result property="province"      column="province"        />
        <result property="city"          column="city"            />
        <result property="tier"          column="tier"            />
        <result property="is985"         column="is_985"          />
        <result property="is211"         column="is_211"          />
        <result property="isDoubleFirst" column="is_double_first" />
        <result property="isPublic"      column="is_public"       />
        <result property="website"       column="website"         />
        <result property="status"        column="status"          />
        <result property="createdAt"     column="created_at"      />
        <result property="updatedAt"     column="updated_at"      />
    </resultMap>

    <sql id="selectSchoolVo">
        select id, name, short_name, province, city, tier, is_985, is_211,
               is_double_first, is_public, website, status, created_at, updated_at
        from school
    </sql>

    <select id="selectSchoolList" parameterType="School" resultMap="SchoolResult">
        <include refid="selectSchoolVo"/>
        <where>
            <if test="name != null and name != ''">
                AND name like concat('%', #{name}, '%')
            </if>
            <if test="province != null and province != ''">
                AND province = #{province}
            </if>
            <if test="city != null and city != ''">
                AND city like concat('%', #{city}, '%')
            </if>
            <if test="tier != null and tier != ''">
                AND tier = #{tier}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by province, city, id desc
    </select>

    <select id="selectSchoolAll" resultMap="SchoolResult">
        <include refid="selectSchoolVo"/>
        where status = 'active'
        order by province, city, name
    </select>

    <select id="selectSchoolById" parameterType="Long" resultMap="SchoolResult">
        <include refid="selectSchoolVo"/>
        where id = #{id}
    </select>

    <select id="checkSchoolNameUnique" parameterType="String" resultMap="SchoolResult">
        <include refid="selectSchoolVo"/>
        where name = #{name}
        limit 1
    </select>

    <insert id="insertSchool" parameterType="School" useGeneratedKeys="true" keyProperty="id">
        insert into school
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="shortName != null">short_name,</if>
            <if test="province != null and province != ''">province,</if>
            <if test="city != null and city != ''">city,</if>
            <if test="tier != null and tier != ''">tier,</if>
            <if test="is985 != null">is_985,</if>
            <if test="is211 != null">is_211,</if>
            <if test="isDoubleFirst != null">is_double_first,</if>
            <if test="isPublic != null">is_public,</if>
            <if test="website != null">website,</if>
            <if test="status != null and status != ''">status,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="shortName != null">#{shortName},</if>
            <if test="province != null and province != ''">#{province},</if>
            <if test="city != null and city != ''">#{city},</if>
            <if test="tier != null and tier != ''">#{tier},</if>
            <if test="is985 != null">#{is985},</if>
            <if test="is211 != null">#{is211},</if>
            <if test="isDoubleFirst != null">#{isDoubleFirst},</if>
            <if test="isPublic != null">#{isPublic},</if>
            <if test="website != null">#{website},</if>
            <if test="status != null and status != ''">#{status},</if>
        </trim>
    </insert>

    <update id="updateSchool" parameterType="School">
        update school
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="shortName != null">short_name = #{shortName},</if>
            <if test="province != null and province != ''">province = #{province},</if>
            <if test="city != null and city != ''">city = #{city},</if>
            <if test="tier != null and tier != ''">tier = #{tier},</if>
            <if test="is985 != null">is_985 = #{is985},</if>
            <if test="is211 != null">is_211 = #{is211},</if>
            <if test="isDoubleFirst != null">is_double_first = #{isDoubleFirst},</if>
            <if test="isPublic != null">is_public = #{isPublic},</if>
            <if test="website != null">website = #{website},</if>
            <if test="status != null and status != ''">status = #{status},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteSchoolById" parameterType="Long">
        delete from school where id = #{id}
    </delete>

    <delete id="deleteSchoolByIds" parameterType="Long">
        delete from school where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
